    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Système de filtrage
            const filterPills = document.querySelectorAll('.filter-pill');
            const trainingCards = document.querySelectorAll('.training-card');

            let activeType = 'all';
            let activeLevel = null;

            filterPills.forEach(pill => {
                pill.addEventListener('click', function() {
                    const filter = this.dataset.filter;
                    const level = this.dataset.level;

                    // Gestion des filtres de type
                    if (filter) {
                        // Retirer la classe active des autres filtres de type
                        document.querySelectorAll('[data-filter]').forEach(p => p.classList.remove('active'));
                        this.classList.add('active');
                        activeType = filter;
                    }

                    // Gestion des filtres de niveau
                    if (level) {
                        if (this.classList.contains('active')) {
                            this.classList.remove('active');
                            activeLevel = null;
                        } else {
                            document.querySelectorAll('[data-level]').forEach(p => p.classList.remove('active'));
                            this.classList.add('active');
                            activeLevel = level;
                        }
                    }

                    // Appliquer les filtres
                    filterTrainings();
                });
            });

            function filterTrainings() {
                trainingCards.forEach(card => {
                    const cardType = card.dataset.type;
                    const cardLevel = card.dataset.level;

                    const typeMatch = activeType === 'all' || cardType === activeType;
                    const levelMatch = !activeLevel || cardLevel === activeLevel;

                    if (typeMatch && levelMatch) {
                        card.style.display = 'block';
                        card.classList.add('animate-fade-in');
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            // Animation d'apparition
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('animate-slide-up');
                    }
                });
            });

            trainingCards.forEach(card => observer.observe(card));
        });
    </script>
</body>
</html>
